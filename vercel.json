{
  "version": 2,
  "builds": [
    {
      "src": "api/compile.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/compile",
      "dest": "/api/compile.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
